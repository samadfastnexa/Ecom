# Django backend server configuration
# Copy this file to .env and adjust the values for your setup.

# Host the dev server binds to.
# 0.0.0.0 makes it reachable from other devices on your network (phones, emulators).
BACKEND_HOST=0.0.0.0

# Port the dev server runs on.
BACKEND_PORT=8001

# Database engine: "postgresql" (local dev) or "mysql" (cPanel shared hosting)
DB_ENGINE=postgresql

# Database connection
# For postgresql: default port 5432. For mysql: default port 3306.
DB_NAME=century
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_HOST=localhost
DB_PORT=5432

# ── Shared hosting (MySQL) example ───────────────────────────────────────────
# On cPanel/shared hosting (MySQL only), set these instead:
#   DB_ENGINE=mysql
#   DB_NAME=cpaneluser_century
#   DB_USER=cpaneluser_dbuser
#   DB_PASSWORD=your_db_password
#   DB_HOST=localhost
#   DB_PORT=3306
# Then run migrations + seed once:
#   python manage.py migrate
#   python manage.py seed
