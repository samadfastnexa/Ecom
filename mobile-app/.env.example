# Backend API Configuration
# Copy this file to .env.
#
# By default (see app.config.js) the app uses the live deployed backend, so
# you don't need to set anything for production.

# ── Option A: full API URL (live or any custom backend) ──────────────────
# Takes priority over API_HOST/API_PORT.
API_URL=https://century.zipnixtechnologies.com/api

# ── Option B: local dev against a backend on your LAN ────────────────────
# Comment out API_URL above and set these instead.
# Find your IP: Windows `ipconfig` (IPv4 Address), Mac/Linux `ifconfig`/`ip addr`.
# API_HOST=YOUR_LOCAL_IP
# API_PORT=8002
