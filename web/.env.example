# ── Web (Next.js admin + storefront) environment ──────────────────────────────
# These are PUBLIC values baked into the browser bundle — never put secrets here.
#
# Used when USE_LOCAL = false in src/lib/constants.ts (production/live).
# For local development you can instead set USE_LOCAL = true in that file, which
# points the app at http://localhost:8002 without needing these vars.

# Backend API base URL (must end with /api)
NEXT_PUBLIC_API_URL=https://century.zipnixtechnologies.com/api

# Base URL where uploaded media (product/complaint images) is served from
NEXT_PUBLIC_MEDIA_URL=https://century.zipnixtechnologies.com
